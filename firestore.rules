rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['playerName', 'score', 'survivedTime', 'timestamp'])
             && data.keys().size() == 4
             && data.playerName is string
             && data.playerName.size() > 0
             && data.playerName.size() <= 20
             && data.score is number
             && data.survivedTime is number
             && data.timestamp is number;
    }
    
    match /leaderboard/{entryId} {
      allow read: if true;
      allow create: if isValidLeaderboardEntry(request.resource.data) && request.resource.data.timestamp == request.time.toMillis();
      allow update: if false;
      allow delete: if false;
    }
  }
}
